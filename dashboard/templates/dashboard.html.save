{% extends "base.html" %}
{% set title="ZeroGuardian-XDR | Dashboard" %}
{% set header="Security Overview" %}

{% block content %}

<div class="zg-grid zg-grid-4">
  <div class="zg-card zg-pad">
    <div class="zg-k">Devices Discovered</div>
    <div class="zg-v text-cyan-200">{{ devices_count }}</div>
    <div class="zg-s">LAN discovery</div>
  </div>

  <div class="zg-card zg-pad">
    <div class="zg-k">Packets Captured</div>
    <div class="zg-v text-cyan-200">{{ traffic.total_packets or 0 }}</div>
    <div class="zg-s">Last {{ traffic.duration_sec or 0 }} sec</div>
  </div>

  <div class="zg-card zg-pad">
    <div class="zg-k">Top Protocol</div>
    <div class="zg-v text-cyan-200">
      {% if traffic.top_protocols %}{{ traffic.top_protocols[0].proto }}{% else %}—{% endif %}
    </div>
    <div class="zg-s">
      {% if traffic.top_protocols %}
        {% for p in traffic.top_protocols[:2] %}
          <span class="zg-tag">{{ p.proto }}: {{ p.count }}</span>
        {% endfor %}
      {% else %}
        No data
      {% endif %}
    </div>
  </div>

  <div class="zg-card zg-pad">
    <div class="zg-k">Anomaly Status</div>
    <div class="zg-v {% if anomalies and anomalies[0].severity=='High' %}text-red-200{% elif anomalies and anomalies[0].severity=='Medium' %}text-yellow-200{% else %}text-green-200{% endif %}">
      {% if anomalies %}{{ anomalies[0].severity }}{% else %}—{% endif %}
    </div>
    <div class="zg-s">Behavior-based detection</div>
  </div>
</div>

<!-- charts row -->
<div class="zg-grid zg-grid-2">
  <div class="zg-card zg-pad">
    <div class="zg-row">
      <div class="zg-title2">Anomaly Trend</div>
      <div class="zg-miniTag">Last 6 points</div>
    </div>
    <div class="zg-chartbox">
      <canvas id="anomalyTrend"></canvas>
    </div>
  </div>

  <div class="zg-card zg-paroto-card">
    <div class="zg-cardhead">
      <div class="zg-cardtitle">Protocol Breakdown</div>
      <div class="zg-zigpill">Capture window</div>
    </div>
    <div class="zg-proto-wrap">
      <canvas id="protoDonut"></canvas>
    </div>
  </div>
</div>

<!-- tables row -->
<div class="zg-grid zg-grid-2">
  <div class="zg-card zg-pad">
    <div class="zg-row">
      <div class="zg-title2">Devices (Preview)</div>
      <a class="zg-link" href="/devices">View all →</a>
    </div>

    <div class="zg-tablewrap">
      <table class="zg-table">
        <thead>
          <tr><th>IP</th><th>Status</th></tr>
        </thead>
        <tbody>
          {% if devices and devices|length>0 %}
            {% for d in devices %}
            <tr>
              <td>{{ d.ip }}</td>
              <td><span class="zg-badge low">{{ d.state }}</span></td>
            </tr>
            {% endfor %}
          {% else %}
            <tr><td colspan="2" class="zg-muted">No devices found (mobile hotspot can block scanning).</td></tr>
          {% endif %}
        </tbody>
      </table>
    </div>
  </div>

  <div class="zg-card zg-pad">
    <div class="zg-row">
      <div class="zg-title2">Anomalies</div>
      <a class="zg-link" href="/ai-threats">AI view →</a>
    </div>

    <div class="zg-stack">
      {% if anomalies and anomalies|length>0 %}
        {% for a in anomalies[:5] %}
          <div class="zg-alert">
            <div class="zg-alert-top">
              <div class="zg-alert-name">{{ a.type }}</div>
              <span class="zg-badge {% if a.severity=='High' %}high{% elif a.severity=='Medium' %}med{% else %}low{% endif %}">
                {{ a.severity }}
              </span>
            </div>
            <div class="zg-alert-desc">{{ a.details }}</div>
          </div>
        {% endfor %}
      {% else %}
        <div class="zg-muted">No anomaly data yet.</div>
      {% endif %}
    </div>
  </div>
</div>

<script>
  // Real protocols data from orchestrator
  const proto = {{ (traffic.top_protocols or [])|tojson }};
  const protoLabels = proto.map(p => p.proto);
  const protoCounts = proto.map(p => p.count);

  // Trend: build from anomaly severity (real, not random)
  const sevMap = { "Low": 20, "Medium": 60, "High": 90 };
  const anomalies = {{ (anomalies or [])|tojson }};
  const base = anomalies.length ? (sevMap[anomalies[0].severity] || 20) : 10;

  const labels = ["T-25","T-20","T-15","T-10","T-5","Now"];
  // Make a small smooth trend around base (still based on real severity)
  const trend = [base-8, base-4, base+2, base-2, base+6, base].map(v => Math.max(0, Math.min(100, v)));

  // Chart defaults (more cyber look)
  Chart.defaults.color = "rgba(226,232,240,0.85)";
  Chart.defaults.borderColor = "rgba(148,163,184,0.10)";

  new Chart(document.getElementById("anomalyTrend"), {
    type: "line",
    data: {
      labels,
      datasets: [{
        label: "Anomaly Score",
        data: trend,
        borderWidth: 2,
        tension: 0.35,
        pointRadius: 2
      }]
    },
    options: {
      plugins: { legend: { display: false } },
      scales: {
        y: { suggestedMin: 0, suggestedMax: 100, grid: { color: "rgba(148,163,184,0.08)" } },
        x: { grid: { color: "rgba(148,163,184,0.06)" } }
      }
    }
  });

  new Chart(document.getElementById("protoDonut"), {
  type: "doughnut",
  data: {
    labels: protoLabels.length ? protoLabels : ["No Data"],
    datasets: [{
      data: protoCounts.length ? protoCounts : [1],
      backgroundColor: protoLables.map(p => {
        if (p === "TCP") return "rgba(0,174,255,0.95)";     // blue neon
        if (p === "UDP") return "rgba(255,50,50,0.95)";      // red
        if (p === "IPv6") return "rgba(140,90,255,0.95)";    // purple
        if (p === "ICMP") return "rgba(255,120,200,0.95)";   // pink
        return "rgba(120,120,120,0.35)";
      }),

      borderColor: protoLables.map(p => {
        if (p === "TCP") return "#00eaff";
        if (p === "UDP") return "#ff2d2d";
        if (p === "IPv6") return "#9a7cff";
        if (p === "ICMP") return "#ff8bdc";
    return "rgba(150,150,150,0.4)";
  }),
      borderWidth: 2,
      hoverOffset: 12
    }]
  },
  options: {
    responsive: true,
    maintainAspectRatio: false,   // ⭐ THIS IS THE KEY
    plugins: {
      legend: {
        position: "bottom",
        labels: { boxWidth: 12 }
      }
    },
    cutout: "68%"
  }
});  
  
</script>

{% endblock %}
